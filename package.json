{
  "name": "user-management-ui",
  "version": "0.1.0",
  "description": "User lifecycle management — onboard, modify, off-board with one click. Provisions GitHub, Slack, M365, GCP, and portal access per role.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "server:dev": "node server/index.js",
    "dev:real": "npm run server:dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit --strict",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoketest": "playwright test",
    "smoketest-no-compile": "playwright test --no-deps",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "quality:gates": "bash scripts/quality-gates.sh",
    "quality:gates:ci": "bash scripts/quality-gates.sh --ci"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.1011.0",
    "@aws-sdk/client-sso-admin": "^3.1010.0",
    "@aws-sdk/client-sts": "^3.1011.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@tanstack/react-query": "^5.17.0",
    "@unified-admin/core": "file:../unified-admin-ui/packages/core",
    "@unified-trading/ui-auth": "file:../unified-trading-ui-auth",
    "@unified-trading/ui-kit": "file:../unified-trading-ui-kit",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.20.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.0.0",
    "pre-commit": "^1.2.2",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "type": "module"
}
