{
  "name": "user-management-ui",
  "version": "0.2.0",
  "description": "User lifecycle management — onboard, modify, off-board with one click. Provisions GitHub, Slack, M365, GCP, and portal access per role.",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 5184",
    "build": "next build",
    "start": "next start -p 5184",
    "server:dev": "node server/index.js",
    "dev:all": "npm run server:dev & npm run dev",
    "lint": "eslint app/ lib/ components/ hooks/",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoketest": "playwright test",
    "smoketest-no-compile": "playwright test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "quality:gates": "bash scripts/quality-gates.sh",
    "quality:gates:ci": "bash scripts/quality-gates.sh --ci"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.1011.0",
    "@aws-sdk/client-sso-admin": "^3.1010.0",
    "@aws-sdk/client-sts": "^3.1011.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.91.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.5",
    "pre-commit": "^1.2.2",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.3.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "type": "module"
}
