# ==============================================================================
# User Management UI + Provisioning Platform Environment Template
# ==============================================================================
# This file is placeholder-only and safe to commit.
# Copy to .env.development, .env.local, or deployment secret manager entries.

# ------------------------------------------------------------------------------
# Frontend runtime flags
# ------------------------------------------------------------------------------
VITE_APP_ENV=development
VITE_APP_VERSION=0.1.0
VITE_SKIP_AUTH=false
VITE_ENABLE_OFFBOARD_PAGE=true
VITE_ENABLE_MODIFY_PAGE=true
VITE_ENABLE_AWS_PROVISIONING=true
VITE_ENABLE_GCP_PROVISIONING=true
VITE_ENABLE_SERVICE_ACCOUNT_FLOW=true
VITE_ENABLE_APPROVALS=true
VITE_ENABLE_AUDIT_LOGS=true

# ------------------------------------------------------------------------------
# UI/backend endpoints
# ------------------------------------------------------------------------------
VITE_API_URL=https://user-mgmt-api.example.com
VITE_USER_MGMT_API_URL=https://user-mgmt-api.example.com/api/v1
VITE_HEALTH_URL=https://user-mgmt-api.example.com/health
VITE_METRICS_URL=https://user-mgmt-api.example.com/metrics
VITE_AUDIT_UI_URL=https://user-mgmt-api.example.com/audit
VITE_WORKFLOW_STATUS_URL=https://user-mgmt-api.example.com/workflows/status

# ------------------------------------------------------------------------------
# Auth/session
# ------------------------------------------------------------------------------
AUTH_PROVIDER=cognito-google-pkce
AUTH_ISSUER=https://auth.example.com
AUTH_AUDIENCE=user-management-ui
AUTH_CLIENT_ID=REPLACE_ME
AUTH_REDIRECT_URI=http://localhost:5184/auth/callback
AUTH_LOGOUT_REDIRECT_URI=http://localhost:5184
JWT_CLOCK_SKEW_SECONDS=60
SESSION_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# ------------------------------------------------------------------------------
# Google Workflows orchestration (preferred over Power Automate)
# ------------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_WORKFLOW_ONBOARD=um-onboard-user
GOOGLE_WORKFLOW_MODIFY=um-modify-user
GOOGLE_WORKFLOW_OFFBOARD=um-offboard-user
GOOGLE_WORKFLOW_REPROVISION=um-reprovision-user
GOOGLE_WORKFLOW_SYNC=um-sync-access
GOOGLE_WORKFLOW_BREAKGLASS_APPROVAL=um-breakglass-approval
GOOGLE_WORKFLOW_QUOTA=um-quota-check
# Optional provider-specific subflows (documented in docs/provider-workflows.md)
GOOGLE_WORKFLOW_GITHUB=um-github-provision
GOOGLE_WORKFLOW_SLACK=um-slack-provision
GOOGLE_WORKFLOW_M365=um-m365-provision
GOOGLE_WORKFLOW_GCP=um-gcp-provision
GOOGLE_WORKFLOW_AWS=um-aws-provision
GOOGLE_WORKFLOW_PORTAL=um-portal-provision
GOOGLE_WORKFLOW_INVOKER_SERVICE_ACCOUNT=svc-user-mgmt-workflows@your-gcp-project-id.iam.gserviceaccount.com
GOOGLE_WORKFLOW_EXECUTION_TIMEOUT_SECONDS=900
GOOGLE_WORKFLOW_POLL_INTERVAL_SECONDS=5
GOOGLE_WORKFLOW_MAX_POLL_ATTEMPTS=120
WORKFLOW_EXECUTION_ENABLED=true
REAL_PROVIDER_EXECUTION_ENABLED=true

# ------------------------------------------------------------------------------
# Google Cloud auth + IAM targets (hybrid model)
# ------------------------------------------------------------------------------
GCP_TARGET_PROJECT_ID=your-target-project-id
GCP_TARGET_PROJECT_NUMBER=123456789012
GCP_TARGET_FOLDER_ID=folders/123456789012
GCP_TARGET_ORG_ID=organizations/123456789012
GCP_WORKFORCE_POOL=workforcePools/your-pool
GCP_WORKFORCE_PROVIDER=providers/your-provider
GCP_DEFAULT_ROLE_ADMIN=roles/editor
GCP_DEFAULT_ROLE_COLLABORATOR=roles/viewer
GCP_DEFAULT_ROLE_OPERATIONS=roles/viewer
GCP_DEFAULT_ROLE_ACCOUNTING=roles/viewer
GCP_BREAKGLASS_ENABLED=false
GCP_BREAKGLASS_APPROVER_GROUP=group:security-admins@odum-research.com
GCP_SERVICE_ACCOUNT_KEY_CREATION_ALLOWED=false
GCP_SERVICE_ACCOUNT_DEFAULT_PROJECT=your-target-project-id
GCP_SERVICE_ACCOUNT_NAME_PREFIX=um-

# ------------------------------------------------------------------------------
# AWS org/account targets (hybrid model)
# ------------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ORG_ID=o-xxxxxxxxxx
AWS_ACCOUNT_ID=123456789012
AWS_IDENTITY_CENTER_INSTANCE_ARN=arn:aws:sso:::instance/ssoins-xxxxxxxxxxxxxxxx
AWS_IDENTITY_STORE_ID=d-xxxxxxxxxx
AWS_PERMISSION_SET_ADMIN_ARN=arn:aws:sso:::permissionSet/ssoins-xxxxxxxxxxxxxxxx/ps-xxxxxxxxxxxxxxxx
AWS_PERMISSION_SET_VIEWER_ARN=arn:aws:sso:::permissionSet/ssoins-xxxxxxxxxxxxxxxx/ps-xxxxxxxxxxxxxxxx
AWS_PERMISSION_SET_FINANCE_ARN=arn:aws:sso:::permissionSet/ssoins-xxxxxxxxxxxxxxxx/ps-xxxxxxxxxxxxxxxx
AWS_PERMISSION_SET_OPS_ARN=arn:aws:sso:::permissionSet/ssoins-xxxxxxxxxxxxxxxx/ps-xxxxxxxxxxxxxxxx
AWS_BREAKGLASS_ENABLED=false
AWS_BREAKGLASS_APPROVER_GROUP=security-admins
AWS_NATIVE_IAM_USER_PREFIX=um-
AWS_NATIVE_IAM_USER_PATH=/odum/user-management/
AWS_DEFAULT_ASSUME_ROLE_ARN=arn:aws:iam::123456789012:role/user-management-automation
AWS_DEFAULT_EXTERNAL_ID=REPLACE_ME

# AWS machine credentials (placeholder only; prefer SSO or role assumption)
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_SESSION_TOKEN=REPLACE_ME_IF_USING_STS

# ------------------------------------------------------------------------------
# GitHub provisioning
# ------------------------------------------------------------------------------
GITHUB_ORG=IggyIkenna
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_ADMIN_PAT=REPLACE_ME
GITHUB_DEFAULT_TEAM_ADMIN=platform-admins
GITHUB_DEFAULT_TEAM_COLLABORATOR=engineering
GITHUB_INVITE_ROLE=direct_member
GITHUB_REPO_ALLOWLIST=repo-a,repo-b,repo-c
GITHUB_REPO_PERMISSION=push

# ------------------------------------------------------------------------------
# Slack provisioning
# ------------------------------------------------------------------------------
SLACK_WORKSPACE_ID=T00000000
SLACK_API_BASE_URL=https://slack.com/api
SLACK_ADMIN_TOKEN=xoxp-REPLACE_ME
SLACK_DEFAULT_CHANNEL_GENERAL=C00000000
SLACK_DEFAULT_CHANNEL_ENGINEERING=C00000001
SLACK_DEFAULT_CHANNEL_FINANCE=C00000002
SLACK_DEFAULT_CHANNEL_OPS=C00000003
SLACK_DEFAULT_CHANNEL_INVESTORS=C00000004
SLACK_AUTO_JOIN_DEFAULT_CHANNELS=true

# ------------------------------------------------------------------------------
# Microsoft 365 / Graph provisioning
# ------------------------------------------------------------------------------
MS_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_SECRET=REPLACE_ME
MS_GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0
MS_GRAPH_SCOPE=https://graph.microsoft.com/.default
MS_DEFAULT_USAGE_LOCATION=US
MS_DEFAULT_LICENSE_SKU=ENTERPRISEPREMIUM
MS_DEFAULT_DOMAIN=odum-research.com
MS_SHAREPOINT_GROUP_ID=00000000-0000-0000-0000-000000000000
COLLABORATOR_M365_ENABLED=true

# ------------------------------------------------------------------------------
# Portal provisioning
# ------------------------------------------------------------------------------
PORTAL_API_BASE_URL=https://odum-research.com/api
PORTAL_SERVICE_TOKEN=REPLACE_ME
PORTAL_DEFAULT_STATUS=active
PORTAL_OFFBOARDED_STATUS=offboarded
PORTAL_DEFAULT_ROLE=viewer

# ------------------------------------------------------------------------------
# Email / notifications
# ------------------------------------------------------------------------------
SENDGRID_API_KEY=SG.REPLACE_ME
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=no-reply@odum-research.com
EMAIL_FROM_NAME=Odum Research
EMAIL_REPLY_TO=support@odum-research.com
ONBOARDING_EMAIL_TEMPLATE_ID=d-REPLACE_ME
OFFBOARDING_EMAIL_TEMPLATE_ID=d-REPLACE_ME
ALERT_EMAIL_TO=security@odum-research.com

# ------------------------------------------------------------------------------
# Approvals and policy controls
# ------------------------------------------------------------------------------
REQUIRE_APPROVAL_FOR_ADMIN_ROLE=true
REQUIRE_APPROVAL_FOR_BREAKGLASS=true
REQUIRE_APPROVAL_FOR_SERVICE_ACCOUNT_CREATE=true
APPROVAL_TTL_HOURS=24
APPROVAL_SLACK_CHANNEL=C00000099
APPROVAL_EMAIL_DISTRIBUTION=it-admins@odum-research.com
POLICY_ENFORCEMENT_MODE=enforce

# ------------------------------------------------------------------------------
# Retry, timeout, and idempotency controls
# ------------------------------------------------------------------------------
PROVISIONING_MAX_RETRIES=3
PROVISIONING_RETRY_BACKOFF_MS=1000
PROVISIONING_STEP_TIMEOUT_SECONDS=120
PROVISIONING_GLOBAL_TIMEOUT_SECONDS=900
IDEMPOTENCY_KEY_TTL_SECONDS=86400
REPROVISION_ALLOW_PARTIAL_SUCCESS=true
SLACK_SEAT_LIMIT=50
M365_LICENSE_LIMIT=25
OFFBOARD_DEFAULT_DEACTIVATE=true

# ------------------------------------------------------------------------------
# Queue / async execution (if backend uses pubsub/tasks)
# ------------------------------------------------------------------------------
QUEUE_PROVIDER=gcp-pubsub
PUBSUB_TOPIC_PROVISIONING=um-provisioning-events
PUBSUB_TOPIC_AUDIT=um-audit-events
PUBSUB_SUBSCRIPTION_PROVISIONING=um-provisioning-worker
TASKS_QUEUE_NAME=um-provisioning-queue
TASKS_LOCATION=us-central1

# ------------------------------------------------------------------------------
# Storage / persistence
# ------------------------------------------------------------------------------
DB_PROVIDER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=user_management
DB_USER=um_app
DB_PASSWORD=REPLACE_ME
REDIS_URL=redis://127.0.0.1:6379

# ------------------------------------------------------------------------------
# Secrets manager references (indirect secret names)
# ------------------------------------------------------------------------------
SECRETS_PROVIDER=gcp-secret-manager
SECRET_REF_GITHUB_ADMIN_PAT=projects/your-gcp-project-id/secrets/github-admin-pat/versions/latest
SECRET_REF_SLACK_ADMIN_TOKEN=projects/your-gcp-project-id/secrets/slack-admin-token/versions/latest
SECRET_REF_MS_GRAPH_CLIENT_SECRET=projects/your-gcp-project-id/secrets/ms-graph-client-secret/versions/latest
SECRET_REF_AWS_ACCESS_KEY_ID=projects/your-gcp-project-id/secrets/aws-access-key-id/versions/latest
SECRET_REF_AWS_SECRET_ACCESS_KEY=projects/your-gcp-project-id/secrets/aws-secret-access-key/versions/latest
SECRET_REF_SENDGRID_API_KEY=projects/your-gcp-project-id/secrets/sendgrid-api-key/versions/latest
SECRET_REF_PORTAL_SERVICE_TOKEN=projects/your-gcp-project-id/secrets/portal-service-token/versions/latest

# ------------------------------------------------------------------------------
# Observability and audit
# ------------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
TRACE_ENABLED=true
METRICS_ENABLED=true
SENTRY_DSN=REPLACE_ME
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com/v1/traces
PROVISIONING_AUDIT_DATASET=user_mgmt_audit
PROVISIONING_AUDIT_TABLE=provisioning_events
PROVISIONING_AUDIT_RETENTION_DAYS=365
AUDIT_SIGNING_KEY_ID=um-audit-signing-key

# ------------------------------------------------------------------------------
# Environment metadata
# ------------------------------------------------------------------------------
ENVIRONMENT=development
REGION=us-central1
TENANT_ID=odum-research
OWNER_TEAM=platform-engineering
