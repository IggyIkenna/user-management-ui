# =============================================================================
# Central .cursorignore — workspace SSOT (reduce Cursor index size)
# Copy to repo root as .cursorignore. Source: unified-trading-pm/scripts/templates/
# =============================================================================

# Venvs and runtimes
**/.venv/
**/.venv-*/
**/venv/
**/.venv-workspace/

# Node
**/node_modules/
**/.next/
**/dist/
**/build/
**/.turbo/

# Python caches and artifacts
**/__pycache__/
**/.mypy_cache/
**/.hypothesis/
**/.ruff_cache/
**/.pytest_cache/
**/.cache/
**/*.egg-info/

# Logs (often large)
**/logs/

# Common data / document file types (large or binary, exclude from index)
**/*.csv
**/*.tsv
**/*.parquet
**/*.xlsx
**/*.xls
**/*.xlsm
**/*.ppt
**/*.pptx
**/*.pptm
**/*.doc
**/*.docx
**/*.docm
**/*.pdf
**/*.ods
**/*.odt
**/*.odp

# Coverage and test output
**/htmlcov/
**/.coverage
**/coverage/
**/.nyc_output/

# IDE / OS
**/.idea/
**/.vscode/
**/.DS_Store
